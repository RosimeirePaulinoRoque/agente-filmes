, \"sábado\"]\n    };\n\n    try {\n        const now = new Date();\n        const dataBr = new Date(now.getTime() + (now.getTimezoneOffset() * 60000) + (3600000 * config.offset));\n        \n        const hour = dataBr.getHours();\n        const day = dataBr.getDay();\n\n        // Regra: Segunda (1) a Sexta (5) e entre 8h e 19h\n        const isWorkTime = config.days.includes(day) && (hour >= config.hours.start && hour < config.hours.end);\n\n        return {\n            isWorkTime: isWorkTime,\n            weekDay: config.names[day]\n        };\n\n    } catch (e) {\n        // Fallback de segurança: assume fechado em caso de erro no script\n        return { isWorkTime: false, weekDay: \"indisponível\" };\n    }\n}","inputVariables":[],"outputVariable":"statusAtendimento","LocalTimeZoneEnabled":false},"conditions":[]}],"$leavingCustomActions":[{"$id":"50ec9029-7480-4c62-8176-c9b4b355a45f","$typeOfContent":"","$description":"","$inputSchema":{"type":"object","properties":{},"required":[]},"type":"TrackEvent","$title":"re:verificahorario","$invalid":false,"settings":{"extras":{"status_disponibilidade":"{{status@isWorkTime}}"},"category":"Atendimento","action":"Verificacao_Horario"},"conditions":[]},{"$id":"7eb9b740-6e18-42c5-ab84-614ca818695f","$typeOfContent":"","$description":"","$inputSchema":{"type":"object","properties":{},"required":[]},"type":"TrackEvent","$title":"re:diadasemana","$invalid":false,"settings":{"extras":{"demanda_por_dia":"{{status@weekDay}}"},"category":"Atendimento","action":"Dia_da_Semana"},"conditions":[]}],"$inputSuggestions":[],"$defaultOutput":{"stateId":"fe5e26cd-2180-410b-813a-0f1a9c9c3e68","$invalid":false,"typeOfStateId":"state"},"$localCustomActions":[],"isAiGenerated":false,"$tags":[],"id":"241091d3-01f1-4714-b7e3-f87b4363d640","root":false,"$title":"[SC] Verifica_Horario_Comercial","$position":{"top":"390px","left":"641px"},"$invalidContentActions":false,"$invalidOutputs":false,"$invalidCustomActions":false,"$invalid":false},"fe5